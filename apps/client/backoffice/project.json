{
    "name": "backoffice",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "projectType": "application",
    "sourceRoot": "apps/client/backoffice/src",
    "prefix": "tagpeak",
    "schematics": {
        "@schematics/angular:component": {
            "style": "scss",
            "standalone": true,
            "skipTests": true
        },
        "@schematics/angular:service": {
            "skipTests": true
        },
        "@schematics/angular:resolver": {
            "skipTests": true
        },
        "@schematics/angular:guard": {
            "skipTests": true
        },
        "@schematics/angular:pipe": {
            "standalone": true,
            "skipTests": true
        },
        "@schematics/angular:directive": {
            "standalone": true,
            "skipTests": true
        },
        "@schematics/angular:application": {
            "strict": true,
            "standalone": true,
            "skipTests": true
        }
    },
    "tags": [],
    "targets": {
        "build": {
            "executor": "@angular-devkit/build-angular:browser-esbuild",
            "outputs": [
                "{options.outputPath}"
            ],
            "options": {
                "outputPath": "apps/dist/apps/backoffice",
                "index": "apps/client/backoffice/src/index.html",
                "main": "apps/client/backoffice/src/main.ts",
                "polyfills": "apps/client/backoffice/src/polyfills.ts",
                "tsConfig": "apps/client/backoffice/tsconfig.app.json",
                "inlineStyleLanguage": "scss",
                "allowedCommonJsDependencies": [
                    "apexcharts",
                    "highlight.js",
                    "crypto-js/enc-utf8",
                    "crypto-js/hmac-sha256",
                    "crypto-js/enc-base64",
                    "flat",
                    "moment",
                    "quill"
                ],
                "assets": [
                    "apps/client/backoffice/src/favicon-16x16.png",
                    "apps/client/backoffice/src/favicon-32x32.png",
                    "apps/client/backoffice/src/assets",
                    "apps/client/backoffice/src/favicon.ico",
                    {
                        "glob": "_redirects",
                        "input": "apps/client/backoffice/src",
                        "output": "/"
                    },
                    "apps/client/backoffice/src/firebase-messaging-sw.js"
                ],
                "stylePreprocessorOptions": {
                    "includePaths": [
                        "src/@fuse/styles"
                    ]
                },
                "styles": [
                    "apps/client/backoffice/src/@fuse/styles/tailwind.scss",
                    "apps/client/backoffice/src/@fuse/styles/themes.scss",
                    "apps/client/backoffice/src/styles/vendors.scss",
                    "apps/client/backoffice/src/@fuse/styles/main.scss",
                    "apps/client/backoffice/src/styles/styles.scss",
                    "apps/client/backoffice/src/styles/tailwind.scss",
                    "apps/client/backoffice/src/styles/stores.scss",
                    "apps/client/backoffice/src/styles/stores-detail.scss"
                ],
                "scripts": []
            },
            "configurations": {
                "production": {
                    "budgets": [
                        {
                            "type": "initial",
                            "maximumWarning": "3mb",
                            "maximumError": "5mb"
                        },
                        {
                            "type": "anyComponentStyle",
                            "maximumWarning": "75kb",
                            "maximumError": "90kb"
                        }
                    ],
                    "fileReplacements": [
                        {
                            "replace": "apps/client/backoffice/src/environments/environment.ts",
                            "with": "apps/client/backoffice/src/environments/environment.prod.ts"
                        }
                    ],
                    "outputHashing": "all"
                },
                "atlanse": {
                    "budgets": [
                        {
                            "type": "initial",
                            "maximumWarning": "3mb",
                            "maximumError": "5mb"
                        },
                        {
                            "type": "anyComponentStyle",
                            "maximumWarning": "75kb",
                            "maximumError": "90kb"
                        }
                    ],
                    "fileReplacements": [
                        {
                            "replace": "apps/client/backoffice/src/environments/environment.ts",
                            "with": "apps/client/backoffice/src/environments/environment.atlanse.ts"
                        }
                    ],
                    "outputHashing": "all"
                },
                "qa": {
                    "budgets": [
                        {
                            "type": "initial",
                            "maximumWarning": "3mb",
                            "maximumError": "5mb"
                        },
                        {
                            "type": "anyComponentStyle",
                            "maximumWarning": "75kb",
                            "maximumError": "90kb"
                        }
                    ],
                    "fileReplacements": [
                        {
                            "replace": "apps/client/backoffice/src/environments/environment.ts",
                            "with": "apps/client/backoffice/src/environments/environment.qa.ts"
                        }
                    ],
                    "outputHashing": "all"
                },
                "pre": {
                    "budgets": [
                        {
                            "type": "initial",
                            "maximumWarning": "3mb",
                            "maximumError": "5mb"
                        },
                        {
                            "type": "anyComponentStyle",
                            "maximumWarning": "75kb",
                            "maximumError": "90kb"
                        }
                    ],
                    "fileReplacements": [
                        {
                            "replace": "apps/client/backoffice/src/environments/environment.ts",
                            "with": "apps/client/backoffice/src/environments/environment.pre.ts"
                        }
                    ],
                    "outputHashing": "all"
                },
                "development": {
                    "buildOptimizer": false,
                    "optimization": false,
                    "vendorChunk": true,
                    "extractLicenses": false,
                    "sourceMap": true,
                    "namedChunks": true
                }
            },
            "defaultConfiguration": "production"
        },
        "serve": {
            "executor": "@angular-devkit/build-angular:dev-server",
            "configurations": {
                "production": {
                    "buildTarget": "backoffice:build:production"
                },
                "development": {
                    "buildTarget": "backoffice:build:development"
                },
                "qa": {
                    "buildTarget": "backoffice:build:qa"
                },
                "pre": {
                    "buildTarget": "backoffice:build:pre"
                }
            },
            "defaultConfiguration": "development"
        },
        "extract-i18n": {
            "executor": "@angular-devkit/build-angular:extract-i18n",
            "options": {
                "buildTarget": "backoffice:build"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint",
            "outputs": [
                "{options.outputFile}"
            ],
            "options": {
                "lintFilePatterns": [
                    "apps/client/backoffice/**/*.ts",
                    "apps/client/backoffice/**/*.html"
                ]
            }
        },
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": [
                "{workspaceRoot}/coverage/{projectRoot}"
            ],
            "options": {
                "jestConfig": "apps/client/backoffice/jest.config.ts",
                "passWithNoTests": true
            }
        }
    }
}
