<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

	<changeSet id="05-blog" author="Atlanse">
		<createTable tableName="translations"
		             remarks="A table to contain translations">

			<column name="id" type="BIGINT" autoIncrement="true">
				<constraints
					nullable="false"
					unique="true"
					primaryKey="true"
					primaryKeyName="translation_PK" />
			</column>

			<column name="version" type="BIGINT">
				<constraints nullable="false" />
			</column>

			<column name="article_id" type="BIGINT">
				<constraints nullable="false"
				             foreignKeyName="fk_translation_article"
				             references="articles(id)"/>
			</column>

			<column name="lang" type="varchar(2)">
				<constraints nullable="false" />
			</column>

			<column name="title" type="varchar(100)">
				<constraints nullable="false" />
			</column>

			<column name="subtitle" type="varchar(120)">
				<constraints nullable="false" />
			</column>

			<column name="content" type="text">
				<constraints nullable="false" />
			</column>

			<column name="enabled" type="boolean">
				<constraints nullable="false" />
			</column>

            <column name="conclusion" type="varchar(255)">
            </column>

		</createTable>
	</changeSet>
</databaseChangeLog>
