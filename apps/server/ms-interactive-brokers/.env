#GO - ECHO
LOGLEVEL=DEBUG #Values: DEBUG | INFO | WARN | ERROR | OFF
BODYLIMIT=4M #Limit can be specified as 4x or 4xB, where x is one of the multiple from K, M, G, T or P.

#GOOSE
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=jdbc:postgresql://localhost:5432/postgres
GOOSE_MIGRATION_DIR=migrations

#LOGGER
LOGGER_LEVEL=2 #Levels: panic - 5, fatal - 4, error - 3, warn - 2, info - 1, debug - 0, trace - -1. Default: 1

#IBKR
CONSUMER_KEY=CHANGE_ME
SIGNATURE_KEY_FP=PATH_TO_CHANGE_ME
ENCRYPTION_KEY_FP=PATH_TO_CHANGE_ME
REALM=CHANGE_ME
DH_PRIME=CHANGE_ME
DH_GENERATOR=2
ACCESS_TOKEN=CHANGE_ME
ACCESS_TOKEN_SECRET=CHANGE_ME
