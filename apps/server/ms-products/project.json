{
    "name": "ms-products",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "apps/server/ms-products/src",
    "projectType": "application",
    "tags": [],
    "targets": {
        "run": {
            "executor": "@nxrocks/nx-micronaut:run",
            "options": {
                "root": "."
            }
        },
        "serve": {
            "executor": "@nxrocks/nx-micronaut:serve",
            "options": {
                "root": "."
            }
        },
        "dockerfile": {
            "executor": "@nxrocks/nx-micronaut:dockerfile",
            "options": {
                "root": "."
            }
        },
        "test": {
            "executor": "@nxrocks/nx-micronaut:test",
            "options": {
                "root": "."
            }
        },
        "clean": {
            "executor": "@nxrocks/nx-micronaut:clean",
            "options": {
                "root": "."
            }
        },
        "build": {
            "executor": "@nxrocks/nx-micronaut:build",
            "options": {
                "root": "."
            },
            "dependsOn": ["^install"],
            "outputs": ["{workspaceRoot}/apps/server/ms-products/build"]
        },
        "aot-sample-config": {
            "executor": "@nxrocks/nx-micronaut:aot-sample-config",
            "options": {
                "root": "."
            }
        }
    }
}
