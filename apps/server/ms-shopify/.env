#GO - ECHO
LOGLEVEL=DEBUG #Values: DEBUG | INFO | WARN | ERROR | OFF
BODYLIMIT=4M #Limit can be specified as 4x or 4xB, where x is one of the multiple from K, M, G, T or P.

#GOOSE
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=jdbc:postgresql://localhost:5432/postgres
GOOSE_MIGRATION_DIR=migrations

#LOGGER
LOGGER_LEVEL=1 #Levels: panic - 5, fatal - 4, error - 3, warn - 2, info - 1, debug - 0, trace - -1. Default: 1

#SHOPIFY
SHOPIFY_API_KEY=CHANGE_ME
SHOPIFY_API_SECRET=CHANGE_ME
SHOPIFY_REDIRECT_URL=CHANGE_ME
SHOPIFY_SCOPE="read_discounts, write_discounts, read_orders, read_script_tags, write_script_tags"
