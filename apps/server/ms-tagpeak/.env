AWIN_REF_PREFIX=TPD

#FILES PATH
PATH_FILE=private_files

#GO JOBS
CURRENCY_EXCHANGE_RATE_JOB=00 01 07 * * * #Currency JOBS TIMER
FIXER_API_KEY=CHANGE_ME #GO - FIXER API KEY
FIXER_DELAY=2 #GO - Delay in seconds between Fixer API calls
FIXER_ATTEMPTS=3 #GO - Number of attempts to make before giving up
IBAN_CHECK_TIMER=00 00 3 * * *
IBAN_FILE_REPLACEMENT_UUID=2a0d248b-3dbc-4b62-b7a0-d44943a6d043
IBKR_UPDATE_TIMER= 00 30 09 * * *
SHOPIFY_ACTIONABLE_TRANSACTIONS_UPDATE_TIMER=0 30 4 * *

#API CALLS
API_CALL_DELAY=2 #GO - Delay in seconds between API calls
API_ATTEMPTS=3 #GO - Number of attempts to make before giving up

#VAT CHECKER
VAT_CHECKER_URL=https://euvatapi.com/api/v1/
VAT_CHECKER_API_KEY=d7068ead65d65c3e9a2e094ad7520f10

#LOGGER
LOGGER_LEVEL=0 #Levels: panic - 5, fatal - 4, error - 3, warn - 2, info - 1, debug - 0, trace - -1. Default: 1

USER_SUBSTITUTION_UUID=d7acd925-0e8c-416e-9ddc-f42b54b5f55b

#CJ TOKEN
