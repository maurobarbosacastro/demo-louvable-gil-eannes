#GO - ECHO
LOGLEVEL=DEBUG #Values: DEBUG | INFO | WARN | ERROR | OFF
BODYLIMIT=5M #Limit can be specified as 4x or 4xB, where x is one of the multiple from K, M, G, T or P.

#GOOSE
GOOSE_DRIVER=postgres
GOOSE_MIGRATION_DIR=migrations

AWIN_ENABLED=false
AWIN_TAGPEAK_PUBLISHER_ID=1256165
