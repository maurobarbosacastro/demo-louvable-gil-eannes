  <bpmn:collaboration id="Collaboration_074943z">
    <bpmn:participant id="Participant_1e558u4" name="Credit Influencer Reward" processRef="credit-influencer-referral" />
    <bpmn:textAnnotation id="TextAnnotation_1gvow63">
      <bpmn:text>Creates a new reward with a fixed value defined by configurations or for the user</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0llbopq">
      <bpmn:text>Add the reward value to the user account balance</bpmn:text>
    </bpmn:textAnnotation>
