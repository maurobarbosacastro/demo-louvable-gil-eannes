    <bpmn:textAnnotation id="TextAnnotation_1ttniz8">
      <bpmn:text>Check if needed to abort due to missing information</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1u0gkfw" associationDirection="None" sourceRef="Gateway_0yvq5kg" targetRef="TextAnnotation_1ttniz8" />
  </bpmn:collaboration>
  <bpmn:process id="send-email" name="Send Email" isExecutable="true">
