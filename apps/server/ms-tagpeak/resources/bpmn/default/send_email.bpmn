    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_0jww3pt</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Activity_0kisx79" name="Get All Email Data">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="get-email-data" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0jww3pt</bpmn:incoming>
      <bpmn:outgoing>Flow_1nkndj7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1l1ujvt" name="Yes" sourceRef="Gateway_0t0rx3a" targetRef="Gateway_1hfkas8">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=isNewsletter = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0n7zq9p" name="Yes" sourceRef="Gateway_1hfkas8" targetRef="Activity_1yhpwqt">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=newsletterOn = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0x0hy72" name="No" sourceRef="Gateway_1hfkas8" targetRef="Event_0liqvew">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=newsletterOn = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_10c8fto" name="No" sourceRef="Gateway_0t0rx3a" targetRef="Activity_1yhpwqt">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=isNewsletter = false</bpmn:conditionExpression>
