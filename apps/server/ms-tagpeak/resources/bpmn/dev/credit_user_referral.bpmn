  <bpmn:collaboration id="Collaboration_1k0n65p">
    <bpmn:participant id="Participant_1e558u4" name="Credit Referral Reward" processRef="credit-user-referral" />
    <bpmn:textAnnotation id="TextAnnotation_1gvow63">
      <bpmn:text>Creates a new reward with the info from the original but with the value 5/10% with the "FINISHED" state</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0llbopq">
      <bpmn:text>Add the reward value to the user account balance</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0gfy27i" associationDirection="None" sourceRef="Activity_0onb4pt" targetRef="TextAnnotation_1gvow63" />
