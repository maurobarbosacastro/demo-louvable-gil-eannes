    <bpmn:textAnnotation id="TextAnnotation_0pzt14x">
      <bpmn:text>Check if needed to abort due to missing information</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0onbidi" associationDirection="None" sourceRef="Gateway_00swixh" targetRef="TextAnnotation_0pzt14x" />
