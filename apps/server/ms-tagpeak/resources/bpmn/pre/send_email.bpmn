  <bpmn:collaboration id="Collaboration_0qvmf4a">
    <bpmn:participant id="Participant_1m5jjue" name="Send Email" processRef="PRE_send-email" />
    <bpmn:textAnnotation id="TextAnnotation_00oczux">
      <bpmn:text>Is Newsletter?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0c05f3b">
      <bpmn:text>If not, sends the email normally</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_14egbud" associationDirection="None" sourceRef="Flow_10c8fto" targetRef="TextAnnotation_0c05f3b" />
    <bpmn:textAnnotation id="TextAnnotation_0sumhwq">
      <bpmn:text>Subscribed?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1qkd0p1">
      <bpmn:text>Get All info for the email
Store, User data ...</bpmn:text>
