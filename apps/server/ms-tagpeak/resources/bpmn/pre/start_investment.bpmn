    <bpmn:sequenceFlow id="Flow_0io8z2q" name="VALIDATED" sourceRef="transaction_validated" targetRef="Activity_06uu9ob">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=transactionState = "VALIDATED"</bpmn:conditionExpression>
