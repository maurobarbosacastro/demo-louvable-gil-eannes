    <bpmn:callActivity id="Activity_1p75hsc" name="Dispatch Cashback Live Notifications">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="PRE_notification-dispatcher" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;casback-live&#34;" target="template_code" />
          <zeebe:input source="=false" target="isNewsletter" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0uxphrb</bpmn:incoming>
      <bpmn:outgoing>Flow_0ytryts</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:association id="Association_1ea60ef" associationDirection="None" sourceRef="start_investment" targetRef="TextAnnotation_1sdzq4t" />
