    <bpmn:textAnnotation id="TextAnnotation_1ossf96">
      <bpmn:text>Transactions changes state from TRACKED to REJECTED or VALIDATED</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1sdzq4t">
      <bpmn:text>Manual task to start the investment

Investment state - LIVE</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1sepds7">
      <bpmn:text>Also to check if the investment is saved in the DB</bpmn:text>
    </bpmn:textAnnotation>
