  <bpmn:collaboration id="Collaboration_100flgc">
    <bpmn:participant id="Participant_0tgt27h" name="MS-TAGPEAK" processRef="QA_Check_Investments" />
    <bpmn:textAnnotation id="TextAnnotation_0aqbh8y">
      <bpmn:text>The Expired verification is done in the code</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1lgb045">
      <bpmn:text>Updates the State with FINISHED or EXPIRED (If the expire flag is on)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_00uhlmb" associationDirection="None" sourceRef="TextAnnotation_0aqbh8y" targetRef="Gateway_1n23tht" />
  </bpmn:collaboration>
  <bpmn:process id="QA_Check_Investments" name="QA_Check Investments" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:extensionElements />
      <bpmn:outgoing>Flow_0rujaka</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1cgr5sb">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">00 01 00 * * *</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:startEvent>
    <bpmn:serviceTask id="QA_check-expired-rewards" name="Verify Expired Rewards">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="QA_check-expired-rewards" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0rujaka</bpmn:incoming>
      <bpmn:outgoing>Flow_0amw7ae</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0rujaka" sourceRef="StartEvent_1" targetRef="QA_check-expired-rewards" />
    <bpmn:exclusiveGateway id="Gateway_1n23tht" default="Flow_167piqc">
      <bpmn:incoming>Flow_0amw7ae</bpmn:incoming>
      <bpmn:outgoing>Flow_167piqc</bpmn:outgoing>
      <bpmn:outgoing>Flow_0sy3y5n</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0amw7ae" sourceRef="QA_check-expired-rewards" targetRef="Gateway_1n23tht" />
    <bpmn:sequenceFlow id="Flow_167piqc" name="Don&#39;t have rewards" sourceRef="Gateway_1n23tht" targetRef="Event_16e50bi" />
    <bpmn:sequenceFlow id="Flow_0sy3y5n" name="Have rewards" sourceRef="Gateway_1n23tht" targetRef="QA_update-expired-rewards">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=not(is empty(rewards))</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="Event_16e50bi">
      <bpmn:incoming>Flow_167piqc</bpmn:incoming>
      <bpmn:incoming>Flow_0w6ci65</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="QA_update-expired-rewards" name="Update Rewards with State">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="QA_update-expired-rewards" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0sy3y5n</bpmn:incoming>
      <bpmn:outgoing>Flow_0u6xqtn</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0u6xqtn" sourceRef="QA_update-expired-rewards" targetRef="Activity_1rn7dee" />
    <bpmn:sequenceFlow id="Flow_0w6ci65" sourceRef="Activity_1rn7dee" targetRef="Event_16e50bi" />
    <bpmn:callActivity id="Activity_1rn7dee" name="End Investment">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="QA_end-investment" propagateAllChildVariables="false" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0u6xqtn</bpmn:incoming>
      <bpmn:outgoing>Flow_0w6ci65</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics>
        <bpmn:extensionElements>
          <zeebe:loopCharacteristics inputCollection="=rewards" inputElement="rewardUuid" />
        </bpmn:extensionElements>
      </bpmn:multiInstanceLoopCharacteristics>
    </bpmn:callActivity>
    <bpmn:association id="Association_1900m2e" associationDirection="None" sourceRef="QA_update-expired-rewards" targetRef="TextAnnotation_1lgb045" />
  </bpmn:process>
