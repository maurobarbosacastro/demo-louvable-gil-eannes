        <zeebe:taskDefinition type="QA_credit-value-to-user" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1q3ncvf</bpmn:incoming>
      <bpmn:outgoing>Flow_1k2x3xn</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:callActivity id="Activity_0p76xw4" name="Dispatch Cashback End Notifications">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="qa-notification-dispatcher" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;reward-finish-and-credited&#34;" target="template_code" />
