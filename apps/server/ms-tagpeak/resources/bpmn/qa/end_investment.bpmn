        <bpmn:flowNodeRef>Credit_Value_To_User</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_0p76xw4</bpmn:flowNodeRef>
        <bpmn:childLaneSet id="LaneSet_0yzgw2k">
          <bpmn:lane id="Lane_1h4v7gd">
            <bpmn:flowNodeRef>Activity_10tpvvv</bpmn:flowNodeRef>
            <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
            <bpmn:flowNodeRef>Activity_1njjxlc</bpmn:flowNodeRef>
