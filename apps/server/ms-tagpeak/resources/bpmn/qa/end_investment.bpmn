      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1k2x3xn</bpmn:incoming>
      <bpmn:outgoing>Flow_0m155fo</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:association id="Association_0uxc1b8" associationDirection="None" sourceRef="Activity_0ud9ynd" targetRef="TextAnnotation_01vvdm6" />
  </bpmn:process>
