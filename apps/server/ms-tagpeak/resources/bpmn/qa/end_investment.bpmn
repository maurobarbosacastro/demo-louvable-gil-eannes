    <bpmn:serviceTask id="Activity_1njjxlc" name="Notify Tagpeak">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="QA_notify-tagpeak-actor" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1nsd60e</bpmn:incoming>
      <bpmn:outgoing>Flow_1e5tiiu</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_0k0w9mt" name="Stop Invesment">
      <bpmn:incoming>Flow_1e5tiiu</bpmn:incoming>
      <bpmn:outgoing>Flow_0xj9i63</bpmn:outgoing>
      <bpmn:outgoing>Flow_0nw5hry</bpmn:outgoing>
      <bpmn:outgoing>Flow_1hwfhqw</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1hwfhqw" name="STOPPED" sourceRef="Gateway_0k0w9mt" targetRef="Activity_1i0fwjf">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=investmentState = "STOPPED"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1e4tycg" sourceRef="Activity_1i0fwjf" targetRef="Activity_0ud9ynd" />
    <bpmn:userTask id="Activity_0ud9ynd" name="Stop Investment/&#10;Verify Investment">
      <bpmn:extensionElements />
      <bpmn:incoming>Flow_0xj9i63</bpmn:incoming>
      <bpmn:incoming>Flow_1e4tycg</bpmn:incoming>
      <bpmn:outgoing>Flow_1ba8yfy</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:callActivity id="Activity_1i0fwjf" name="Dispatch Stopped Notifications">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="qa-notification-dispatcher" propagateAllChildVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;stop-request&#34;" target="template_code" />
          <zeebe:input source="=false" target="isNewsletter" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1hwfhqw</bpmn:incoming>
      <bpmn:outgoing>Flow_1e4tycg</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:callActivity id="Activity_07ml6yk" name="Credit Referral ">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="QA_credit-user-referral" propagateAllChildVariables="false" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1meoe2j</bpmn:incoming>
      <bpmn:incoming>Flow_0nw5hry</bpmn:incoming>
      <bpmn:outgoing>Flow_1q3ncvf</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:serviceTask id="Update_Reward_Status" name="Update Reward Status (Finished)">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="QA_update-reward-status" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1ba8yfy</bpmn:incoming>
      <bpmn:outgoing>Flow_1meoe2j</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1k2x3xn" sourceRef="Credit_Value_To_User" targetRef="Activity_0p76xw4" />
