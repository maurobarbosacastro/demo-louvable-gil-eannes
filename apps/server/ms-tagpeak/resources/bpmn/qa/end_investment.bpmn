            <bpmn:flowNodeRef>Event_0kodsmt</bpmn:flowNodeRef>
            <bpmn:flowNodeRef>Credit_Value_To_User</bpmn:flowNodeRef>
            <bpmn:flowNodeRef>Activity_0p76xw4</bpmn:flowNodeRef>
          </bpmn:lane>
        </bpmn:childLaneSet>
      </bpmn:lane>
      <bpmn:lane id="Lane_0gokpj7" name="TAGPEAK ACTOR">
        <bpmn:flowNodeRef>Activity_0ud9ynd</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Update_Reward_Status</bpmn:flowNodeRef>
        <bpmn:childLaneSet id="LaneSet_1crehun">
          <bpmn:lane id="Lane_1b3hep3">
            <bpmn:flowNodeRef>Activity_0ud9ynd</bpmn:flowNodeRef>
            <bpmn:flowNodeRef>Update_Reward_Status</bpmn:flowNodeRef>
          </bpmn:lane>
        </bpmn:childLaneSet>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:manualTask id="Activity_10tpvvv" name="End Investment">
      <bpmn:incoming>Flow_03vvask</bpmn:incoming>
      <bpmn:outgoing>Flow_1nsd60e</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_03vvask</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_0xj9i63" name="EXPIRED" sourceRef="Gateway_0k0w9mt" targetRef="Activity_0ud9ynd">
      <bpmn:extensionElements />
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=investmentState = "EXPIRED"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0nw5hry" name="FINISHED" sourceRef="Gateway_0k0w9mt" targetRef="Activity_07ml6yk">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=investmentState = "FINISHED"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1nsd60e" sourceRef="Activity_10tpvvv" targetRef="Activity_1njjxlc" />
    <bpmn:sequenceFlow id="Flow_03vvask" sourceRef="StartEvent_1" targetRef="Activity_10tpvvv" />
    <bpmn:sequenceFlow id="Flow_1ba8yfy" sourceRef="Activity_0ud9ynd" targetRef="Update_Reward_Status" />
