<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1p9vcbk" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.39.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.6.0">
  <bpmn:collaboration id="Collaboration_04gbqns">
    <bpmn:participant id="Participant_1twcxn5" name="End Investment" processRef="QA_end-investment" />
    <bpmn:textAnnotation id="TextAnnotation_0gvaadu">
      <bpmn:text>End of investment 
 - Sopped by the user
 - Finished or Expired</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_01vvdm6">
      <bpmn:text>Join the two manual tasks because Stop Investment and verify investment will be done at the same time

Call endpoint to save the data in DB</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0ke1p7s">
      <bpmn:text>After verify the investment and all the fields are saved the state will be automatically updated to FINISHED</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1ve937u" associationDirection="None" sourceRef="Flow_1ba8yfy" targetRef="TextAnnotation_0ke1p7s" />
    <bpmn:association id="Association_1nrmi7j" associationDirection="None" sourceRef="Activity_10tpvvv" targetRef="TextAnnotation_0gvaadu" />
    <bpmn:textAnnotation id="TextAnnotation_0g31gkp">
      <bpmn:text>Send email to user that the he want to stop the reward</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1nbksl3" associationDirection="None" sourceRef="Activity_1i0fwjf" targetRef="TextAnnotation_0g31gkp" />
    <bpmn:textAnnotation id="TextAnnotation_02yrs3c">
      <bpmn:text>Send email to the user, with the value credited in the tagpeak account</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1n6cv59" associationDirection="None" sourceRef="Activity_0p76xw4" targetRef="TextAnnotation_02yrs3c" />
    <bpmn:textAnnotation id="TextAnnotation_0di3ijw">
      <bpmn:text>If the user was referred this sub process will credit the amount to the referrer</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0ya164r" associationDirection="None" sourceRef="Activity_07ml6yk" targetRef="TextAnnotation_0di3ijw" />
  </bpmn:collaboration>
  <bpmn:process id="QA_end-investment" name="QA_End Investment" isExecutable="true">
    <bpmn:laneSet id="LaneSet_13yynwj">
      <bpmn:lane id="Lane_0rpes9m" name="MS-TAGPEAK">
        <bpmn:flowNodeRef>Activity_10tpvvv</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_1njjxlc</bpmn:flowNodeRef>
