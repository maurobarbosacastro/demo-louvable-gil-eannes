    <bpmn:textAnnotation id="TextAnnotation_13rddhn">
      <bpmn:text>Check if needed to abort due to missing information</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_14cswv5" associationDirection="None" sourceRef="Gateway_01w0vw3" targetRef="TextAnnotation_13rddhn" />
